{
  "name": "pixel-agent-web",
  "version": "1.0.0",
  "description": "Pixel art office where AI agents come to life as animated characters",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/statezeropy/pixel-agent-web"
  },
  "scripts": {
    "install:client": "cd client && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "client:dev": "cd client && npm run dev",
    "backend:dev": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"npm run backend:dev\" \"npm run client:dev\"",
    "build": "cd client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
