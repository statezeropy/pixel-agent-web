# ── Database ──
DATABASE_URL=postgresql+asyncpg://pixel:pixel@localhost:5432/pixel_agents
POSTGRES_DB=pixel_agents
POSTGRES_USER=pixel
POSTGRES_PASSWORD=changeme

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Default LLM ──
LLM_PROVIDER=google
LLM_MODEL=gemini-3.1-flash-lite-preview

# ── LLM API Keys ──
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Tool API Keys ──
TAVILY_API_KEY=

# ── CORS ──
CORS_ORIGINS=http://localhost:5173

# ── App ──
APP_ENV=development
MAX_AGENTS_PER_USER=5
TOOL_TIMEOUT_SEC=120
